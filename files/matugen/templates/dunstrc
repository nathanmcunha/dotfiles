[global]
frame_color = "{{colors.on_surface_variant.default.hex}}"
separator_color= frame
font = "JetBrainsMono Nerd Font Regular 11"
corner_radius = 10
offset = 5x5
origin = top-right
notification_limit = 8
gap_size = 7
frame_width = 2
width = 300
height = 100
follow = keyboard

[urgency_low]
background = "{{colors.surface.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"

[urgency_normal]
background = "{{colors.surface.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"

[urgency_critical]
background = "{{colors.surface.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"
frame_color = "{{colors.gruv_orange.default.hex}}"
